# Discord bot token (Developer Portal > Your App > Bot > Reset Token)
DISCORD_TOKEN=

# Application (client) ID, used when registering slash commands
DISCORD_CLIENT_ID=

# Optional: restrict where the bot posts calendar links.
# If unset, the bot posts in the guild's system channel (falling back to the
# first text channel it can send to).
DISCORD_ANNOUNCE_CHANNEL_ID=
