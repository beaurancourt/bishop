# Discord bot token (Developer Portal > Your App > Bot > Reset Token)
DISCORD_TOKEN=

# Application (client) ID, used when registering slash commands
DISCORD_CLIENT_ID=

# Optional: restrict where the bot posts calendar links.
# If unset, the bot posts in the guild's system channel (falling back to the
# first text channel it can send to).
DISCORD_ANNOUNCE_CHANNEL_ID=

# --- Local HTTP message endpoint (used by the digest job) ---
# Shared secret required to POST /dm. If unset, the endpoint is disabled.
BISHOP_HTTP_TOKEN=
# Where the endpoint listens. Keep on loopback unless something off-box needs it.
BISHOP_HTTP_HOST=127.0.0.1
BISHOP_HTTP_PORT=8787
# Numeric Discord user ID to DM by default (Developer Mode > right-click you >
# Copy User ID). The bot must share a server with this user to DM them.
DISCORD_DM_USER_ID=
